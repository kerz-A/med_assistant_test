# ============================================================
# LLM Provider — choose ONE: ollama (local) or groq (cloud)
# ============================================================

# --- Option A: Groq (cloud, best quality, recommended) ---
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Option B: Ollama (local, no API key, lower quality) ---
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_MODEL=qwen2.5:3b

# ============================================================
# Whisper ASR
# ============================================================
# Models: tiny, base, small, medium, large-v3
# Device: auto (uses GPU if available) | cpu
# Compute: float16 (GPU) | int8 (CPU)
WHISPER_MODEL=medium
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=float16

# ============================================================
# Pyannote Diarization
# ============================================================
# Get token at https://huggingface.co/settings/tokens
# Required for speaker diarization model download
HF_TOKEN=your_hf_token_here

# ============================================================
# Processing
# ============================================================
PROCESSING_INTERVAL_SECONDS=8
AUDIO_BUFFER_DURATION_SECONDS=120
NUM_SPEAKERS=2
