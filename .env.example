# ============================================================
# LLM Provider — выберите ОДИН вариант
# ============================================================

# --- Вариант A: GigaChat (облачный, 1М бесплатных токенов/год) ---
LLM_PROVIDER=gigachat
GIGACHAT_AUTH_KEY=ваш_authorization_key_из_лк
GIGACHAT_MODEL=GigaChat-2-Max

# --- Вариант B: Ollama (локальный, GPU, без API-ключа) ---
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_MODEL=qwen2.5:3b          # 3b (~2ГБ VRAM), 7b (~5ГБ), 14b (~10ГБ, рекомендовано)

# ============================================================
# Whisper ASR
# ============================================================
# Модели: tiny, base, small, medium, large-v3
# Device: auto (GPU если доступен) | cpu
# Compute: float16 (GPU) | int8 (CPU)
WHISPER_MODEL=medium
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=float16

# ============================================================
# LLM pacing (настройка под провайдера)
# ============================================================
# GigaChat: LLM_MIN_GAP_SECONDS=0.0, LLM_MAX_CONCURRENT=1
# Ollama:   LLM_MIN_GAP_SECONDS=0.0, LLM_MAX_CONCURRENT=1
# LLM_MIN_GAP_SECONDS=0.0
# LLM_MAX_CONCURRENT=1
